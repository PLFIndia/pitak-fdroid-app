# Pitak release-signing credentials — sample / template.
#
# Copy this file to `keystore.properties` (which is gitignored) ONLY if you
# prefer the file fallback. The recommended workflow is to export the
# PITAK_UPLOAD_* environment variables from your shell (sourced from a
# password manager) so the passwords never sit on disk.
#
# If `keystore.properties` exists at the repo root, the values below are read
# by app/build.gradle.kts as a fallback when the matching env var is not set.
#
# Path to the upload keystore. Must be absolute.
storeFile=/Users/you/keys/pitak-upload.jks
# Key alias inside the keystore.
keyAlias=pitak-upload
# Keystore password. Treat as a secret; do NOT commit a populated copy of
# this file (the real one is named keystore.properties, which is in
# .gitignore — this `.example` file ships only the template values).
storePassword=replace-me
# Key password. Often the same as the keystore password.
keyPassword=replace-me
